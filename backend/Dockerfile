FROM node:20-slim

RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

RUN npx prisma generate
RUN npm run build

# Fix: copy generated prisma client into dist so Node can find it at runtime
RUN cp -r generated dist/generated

EXPOSE 5000
CMD ["npm", "start"]