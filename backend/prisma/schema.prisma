// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  AGENT
  MANAGER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  LOST
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

enum DealStage {
  NEGOTIATION
  AGREEMENT
  CLOSED
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  role         Role          @default(AGENT)
  leads        Lead[]
  properties   Property[]
  deals        Deal[]
  interactions Interaction[]
  tasks        Task[]        // Track agent task assignments [cite: 62]
}

model Lead {
  id           String     @id @default(uuid())
  name         String
  phone        String
  email        String?
  budget       Float?
  preference   String?
  source       String?    // e.g., Website, Ads [cite: 6]
  status       LeadStatus @default(NEW)
  agent        User       @relation(fields: [agentId], references: [id])
  agentId      String
  clients      Client[]
  followUpDate DateTime?  // For reminders [cite: 10]
  createdAt    DateTime   @default(now())
}

model Property {
  id          String         @id @default(uuid())
  title       String
  description String
  location    String         // [cite: 20]
  latitude    Float?         // Added for Map Integration 
  longitude   Float?         // Added for Map Integration 
  price       Float
  size        Float
  type        String         // Residential/Commercial [cite: 19]
  amenities   String?
  images      String[]       // Array of URLs [cite: 25]
  status      PropertyStatus @default(AVAILABLE)
  agent       User           @relation(fields: [agentId], references: [id])
  agentId     String
  deals       Deal[]
}

model Client {
  id           String        @id @default(uuid())
  name         String
  phone        String
  email        String?
  type         String        // Buyer/Seller [cite: 30]
  lead         Lead?         @relation(fields: [leadId], references: [id])
  leadId       String?
  deals        Deal[]
  interactions Interaction[]
}

model Deal {
  id               String    @id @default(uuid())
  stage            DealStage @default(NEGOTIATION)
  commissionAmount Float?    // [cite: 42, 45]
  closingDate      DateTime?
  documents        String[]  // Array of URLs for agreements/contracts 
  client           Client    @relation(fields: [clientId], references: [id])
  clientId         String
  property         Property  @relation(fields: [propertyId], references: [id])
  propertyId       String
  agent            User      @relation(fields: [agentId], references: [id])
  agentId          String
  createdAt        DateTime  @default(now())
}

model Interaction {
  id        String   @id @default(uuid())
  type      String   // Call, SMS, Email [cite: 50]
  notes     String?
  timestamp DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id])
  clientId  String
  agent     User     @relation(fields: [agentId], references: [id])
  agentId   String
}

// Added for Task assignment and Notifications 
model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  agent       User     @relation(fields: [agentId], references: [id])
  agentId     String
  createdAt   DateTime @default(now())
}